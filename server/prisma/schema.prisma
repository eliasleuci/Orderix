generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  products    Product[]
  ingredients Ingredient[]
  orders      Order[]

  @@map("branches")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(CASHIER)
  branchId    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch   @relation(fields: [branchId], references: [id])
  orders      Order[]
  stockMovements StockMovement[]

  @@index([branchId])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  image       String?
  categoryId  String
  branchId    String
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category @relation(fields: [categoryId], references: [id])
  branch      Branch   @relation(fields: [branchId], references: [id])
  recipe      RecipeItem[]
  orderItems  OrderItem[]

  @@index([branchId])
  @@index([categoryId])
  @@map("products")
}

model Ingredient {
  id          String    @id @default(uuid())
  name        String
  unit        String    // gr, ml, unit, etc.
  stock       Float     @default(0)
  minStock    Float     @default(0)
  categoryId  String?
  branchId    String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch      Branch    @relation(fields: [branchId], references: [id])
  category    IngredientCategory? @relation(fields: [categoryId], references: [id])
  recipeItems RecipeItem[]
  movements   StockMovement[]

  @@index([branchId])
  @@index([categoryId])
  @@map("ingredients")
}

model IngredientCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients Ingredient[]

  @@map("ingredient_categories")
}

enum MovementType {
  ADD       // Reposición manual
  REMOVE    // Consumo por orden
  ADJUST    // Ajuste manual (positvo o negativo)
  INITIAL   // Stock inicial
}

model StockMovement {
  id            String        @id @default(uuid())
  ingredientId  String
  userId        String?
  type          MovementType
  quantity      Float         // Cantidad cambiada (puede ser negativa)
  stockBefore   Float         // Stock antes del cambio
  stockAfter    Float         // Stock después del cambio
  reason        String?       // Nota o motivo del cambio
  createdAt     DateTime      @default(now())

  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])

  @@index([ingredientId])
  @@index([createdAt])
  @@map("stock_movements")
}

model RecipeItem {
  id            String     @id @default(uuid())
  productId     String
  ingredientId  String
  quantity      Float      // Cuánto de este ingrediente usa el producto

  product       Product    @relation(fields: [productId], references: [id])
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([productId, ingredientId])
  @@map("recipe_items")
}

model Order {
  id          String      @id @default(uuid())
  orderNumber Int         @default(autoincrement())
  status      OrderStatus @default(PENDING)
  total       Decimal     @db.Decimal(10, 2)
  branchId    String
  userId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch      Branch      @relation(fields: [branchId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]

  @@index([branchId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2) // Precio al momento de la venta

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}
