{
  "version": 2,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/src/**",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|landing/|favicon.ico|icono.ico|img/).*)",
      "destination": "/index.html"
    }
  ]
}
